<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="cn.edu.cdu.pitsafety.system.mapper.DeviceInfoMapper">

    <resultMap id="BaseResultMap" type="cn.edu.cdu.pitsafety.system.entity.DeviceInfo">
        <id column="id" property="id"/>
        <result column="device_code" property="deviceCode"/>
        <result column="device_name" property="deviceName"/>
        <result column="device_type" property="deviceType"/>
        <result column="owner_id" property="ownerId"/>
        <result column="ip_grade" property="ipGrade"/>
        <result column="maintenance_cycle" property="maintenanceCycle"/>
        <result column="status" property="status"/>
        <result column="create_time" property="createTime"/>
    </resultMap>

    <select id="selectList" resultMap="BaseResultMap">
        SELECT * FROM device_info ORDER BY id DESC
    </select>

    <insert id="insert" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO device_info (device_code, device_name, device_type, owner_id, ip_grade, maintenance_cycle, status)
        VALUES (#{deviceCode}, #{deviceName}, #{deviceType}, #{ownerId}, #{ipGrade}, #{maintenanceCycle}, #{status})
    </insert>

    <update id="updateStatus">
        UPDATE device_info SET status = #{status} WHERE id = #{id}
    </update>

</mapper>